---
import { sitePath } from "../lib/paths";

const links = [
  { path: "/", label: "Start" },
  { path: "/o-nas", label: "O nas" },
  { path: "/wydarzenia", label: "Wydarzenia" },
  { path: "/dolacz", label: "Dołącz" },
  { path: "/kontakt", label: "Kontakt" }
];

const normalizePath = (value: string) => {
  if (value === "/") return "/";
  return value.replace(/\/+$/, "");
};

const path = normalizePath(Astro.url.pathname);
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-base-950/85 backdrop-blur-xl">
  <div class="shell flex items-center justify-between gap-6 py-4">
    <a href={sitePath("/")} class="flex items-center gap-3 text-white" aria-label="Hackerspace Kielce - strona główna">
      <img
        src={sitePath("/logo.png")}
        alt="Logo Hackerspace Kielce"
        class="h-12 w-12 rounded-2xl border border-accent/30 bg-base-900 object-cover shadow-glow"
      />
      <span>
        <span class="block text-lg font-semibold">Hackerspace Kielce</span>
        <span class="block text-sm text-steel">Kod, hardware, społeczność</span>
      </span>
    </a>

    <nav aria-label="Główna nawigacja">
      <ul class="flex flex-wrap items-center justify-end gap-2 text-sm sm:gap-3">
        {
          links.map((link) => {
            const href = sitePath(link.path);
            const active = path === normalizePath(href);

            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    "rounded-full px-4 py-2",
                    active
                      ? "bg-white/10 text-white"
                      : "text-slate-300 hover:bg-white/5 hover:text-white"
                  ]}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>
