---
interface Props {
  eyebrow: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<div class="max-w-2xl">
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">{title}</h2>
  {text && <p class="mt-4 text-lg leading-8 text-slate-300">{text}</p>}
</div>
