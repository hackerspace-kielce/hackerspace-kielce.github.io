---
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

const channels = [
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/company/example",
    text: "Placeholder dla komunikacji zawodowej i partnerstw."
  },
  {
    name: "Facebook",
    href: "https://www.facebook.com/example",
    text: "Placeholder dla lokalnych ogłoszeń i wydarzeń społecznościowych."
  },
  {
    name: "Discord",
    href: "https://discord.gg/example",
    text: "Placeholder dla codziennej komunikacji, pytań i organizacji spotkań."
  },
  {
    name: "GitHub",
    href: "https://github.com/example",
    text: "Placeholder dla projektów open-source, dokumentacji i eksperymentów."
  }
];
---

<MainLayout
  title="Kontakt | Hackerspace Kielce"
  description="Kontakt do społeczności Hackerspace Kielce."
>
  <section class="shell py-16 sm:py-20">
    <SectionHeading
      eyebrow="Kontakt"
      title="Napisz, jeśli chcesz współtworzyć hackerspace w Kielcach"
      text="Ta wersja strony jest w pełni statyczna, więc zamiast backendowego formularza podajemy proste kanały kontaktu. Możesz później podmienić placeholdery na realne profile i adresy."
    />

    <div class="mt-10 grid gap-6 lg:grid-cols-[1fr_0.9fr]">
      <div class="panel p-7">
        <h3 class="text-2xl font-semibold text-white">Kanały</h3>
        <div class="mt-6 grid gap-4">
          {channels.map((channel) => (
            <a
              class="rounded-2xl border border-white/10 bg-white/5 p-5 hover:border-accent/40 hover:bg-white/10"
              href={channel.href}
              target="_blank"
              rel="noreferrer"
            >
              <div class="flex items-center justify-between gap-4">
                <span class="text-lg font-semibold text-white">{channel.name}</span>
                <span class="font-mono text-sm text-accent-soft">link</span>
              </div>
              <p class="mt-3 leading-7 text-slate-300">{channel.text}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="panel p-7">
        <h3 class="text-2xl font-semibold text-white">Kontakt lokalny</h3>
        <div class="mt-5 space-y-4 leading-7 text-slate-300">
          <p>
            Miasto: <span class="text-white">Kielce, Polska</span>
          </p>
          <p>
            E-mail placeholder: <a class="text-accent-soft hover:text-white" href="mailto:kontakt@example.com">kontakt@example.com</a>
          </p>
          <p>
            Jeśli chcesz pomóc organizacyjnie, zaproponować temat warsztatu albo wesprzeć rozwój miejsca,
            odezwij się dowolnym kanałem.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="shell py-16 pb-24">
    <div class="panel p-8 sm:p-10">
      <p class="eyebrow">Bez backendu</p>
      <h2 class="mt-3 text-3xl font-semibold text-white">Prosty kontakt, prosty deployment</h2>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-300">
        Strona jest przygotowana jako statyczny serwis Astro. Dzięki temu można ją wdrożyć na GitHub
        Pages, Netlify, Cloudflare Pages lub dowolny hosting plików statycznych bez utrzymywania serwera.
      </p>
    </div>
  </section>
</MainLayout>
